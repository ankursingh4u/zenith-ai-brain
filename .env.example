# ============================================================
#  Zenith AI Brain — configuration.
#  Local: copy to ".env" and fill in.
#  Coolify: set each of these as an Environment Variable in the UI.
#  NEVER commit real secrets.
# ============================================================

# --- Telegram ---  (from @BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# --- OpenAI ---  (platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Security ---
# Generate once & keep forever:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Owner Telegram IDs (comma-separated) — skip the access gate. From @userinfobot.
ALLOWED_TELEGRAM_IDS=

# --- Access gate (everyone else must enter this code) ---
GODFATHER_QUESTION=🔒 Access check — who's the Godfather?
GODFATHER_ANSWER=change-me
MAX_CODE_ATTEMPTS=5
BAN_HOURS=24

# --- Shared Google service account (default for basic sheet tasks) ---
# EITHER point to a file...
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# ...OR (recommended for hosting) paste the whole JSON as one line here instead:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# --- OAuth login (per-user Gmail/Calendar/Docs/Drive) ---
# The public callback URL. Local: http://localhost:8000/oauth/callback
# Hosted (Coolify): https://<your-app-url>/oauth/callback  (must be https)
OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
# Port the callback server listens on (Coolify may set PORT automatically).
PORT=8000

# --- Scheduler ---
TIMEZONE=Asia/Kolkata
DAILY_JOB_HOUR=9
DUE_REMINDER_DAYS=3

# --- Storage ---
# Local: sqlite:///brain.db
# Coolify: sqlite:////data/brain.db  (with a persistent volume mounted at /data)
DATABASE_URL=sqlite:///brain.db
